generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  draft
  in_progress
  completed
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  cnic      String   @unique
  phone     String
  address   String
  notes     String?
  createdAt DateTime @default(now())

  cases Case[]
}

model Case {
  id              Int        @id @default(autoincrement())
  clientId        Int
  caseType        String
  status          CaseStatus @default(draft)
  propertyDetails String
  notes           String
  createdAt       DateTime   @default(now())

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([clientId])
}

/// Legal document template: `content` holds {{placeholder}} tokens; `fields` drives the UI form (JSON array).
model Template {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.Text
  fields    Json
  createdAt DateTime @default(now())
  documents Document[]

  @@map("templates")
}

model Document {
  id               Int      @id @default(autoincrement())
  templateId       Int
  caseId           Int?
  generatedContent String   @db.Text
  createdAt        DateTime @default(now())
  template         Template @relation(fields: [templateId], references: [id], onDelete: Restrict)
  case             Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([caseId])

  @@map("documents")
}
