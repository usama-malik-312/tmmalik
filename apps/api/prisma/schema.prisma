generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CaseStatus {
  draft
  in_progress
  submitted
  completed
  rejected
}

enum ActivityEntityType {
  client
  case
  document
  template
}

enum UserRole {
  admin
  staff
}

model Activity {
  id                String             @id @default(uuid())
  entityType        ActivityEntityType
  entityId          String
  action            String
  metadata          Json?
  actorUserId       Int?
  actorNameSnapshot String?
  createdAt         DateTime           @default(now())

  actor User? @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@map("activities")
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  cnic      String   @unique
  phone     String
  address   String
  notes     String?
  createdAt DateTime @default(now())

  cases    Case[]
  archives Archive[]
}

model Case {
  id              Int        @id @default(autoincrement())
  clientId        Int
  caseType        String
  status          CaseStatus @default(draft)
  propertyDetails String
  notes           String
  feeType         String?
  feeAmount       Float?
  stampDuty       Float?
  cvt             Float?
  totalFee        Float?
  createdAt       DateTime   @default(now())

  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  documents Document[]

  @@index([clientId])
}

/// Legal document template: `content` holds {{placeholder}} tokens; `fields` drives the UI form (JSON array).
model Template {
  id        Int      @id @default(autoincrement())
  name      String
  content   String   @db.Text
  language  String   @default("en")
  fields    Json
  createdAt DateTime @default(now())
  documents Document[]

  @@map("templates")
}

model Document {
  id               Int      @id @default(autoincrement())
  templateId       Int
  caseId           Int?
  generatedContent String   @db.Text
  qrCode           String?  @db.Text
  verificationId   String   @unique
  createdAt        DateTime @default(now())
  template         Template @relation(fields: [templateId], references: [id], onDelete: Restrict)
  case             Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([templateId])
  @@index([caseId])

  @@map("documents")
}

model User {
  id        Int      @id @default(autoincrement())
  fname     String
  lname     String
  email     String   @unique
  password  String
  address   String
  userType  Int
  role      UserRole @default(staff)
  createdAt DateTime @default(now())

  activities        Activity[]
  userOrganizations UserOrganization[]

  @@map("users")
}

model Organization {
  id                Int                @id @default(autoincrement())
  name              String
  createdAt         DateTime           @default(now())
  userOrganizations UserOrganization[]
}

model UserOrganization {
  userId Int
  orgId  Int

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
}

model Archive {
  id           Int      @id @default(autoincrement())
  clientId     Int?
  title        String
  documentType String
  fileUrl      String
  metadata     Json?
  createdAt    DateTime @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([documentType])
  @@map("archives")
}
